---
import { Image } from "astro:assets";
import avatarImage from "../assets/avatar.jpg";
import robomasterHeroImage from "../assets/robomaster-hero.jpg";
import Layout from "../layouts/Layout.astro";
import { experiences, profile, projects, siteMeta } from "../data/site";

const navigation = [
  { label: "About", href: "#about" },
  { label: "Projects", href: "#projects" },
  { label: "Experience", href: "#experience" },
  { label: "Contact", href: "#contact" },
] as const;

const currentYear = new Date().getFullYear();
const opensNewWindow = (href: string) => href.startsWith("http");
---

<Layout title={siteMeta.title} description={siteMeta.description}>
  <a class="skip-link" href="#main-content">跳到正文</a>

  <header class="site-header">
    <div class="nav-shell">
      <a class="brand" href="#top" aria-label="五水 water5，返回首页顶部">
        <svg class="brand-mark" viewBox="0 0 40 40" aria-hidden="true">
          <circle cx="20" cy="20" r="17" fill="none" />
          <path d="M20 6c-4 7-9 12-9 19a9 9 0 0 0 18 0c0-7-5-12-9-19Z" />
          <path class="brand-mark-cross" d="M20 14v18M11 23h18" />
          <circle class="brand-mark-core" cx="20" cy="23" r="3.5" />
        </svg>
        <span class="brand-copy">
          <strong>{profile.name}</strong>
          <span>{profile.handle}</span>
        </span>
      </a>

      <div class="nav-rail">
        <nav class="primary-nav" aria-label="主导航">
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>

        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="切换主题"
          aria-pressed="false"
        >
          <span class="theme-icon theme-icon--sun" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="3.5" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42" />
            </svg>
          </span>
          <span class="theme-icon theme-icon--moon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M20.2 15.2A8.5 8.5 0 0 1 8.8 3.8a8.5 8.5 0 1 0 11.4 11.4Z" />
            </svg>
          </span>
        </button>
      </div>
    </div>
  </header>

  <main id="main-content" tabindex="-1">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <div class="container hero-grid">
        <div class="hero-copy reveal reveal--one">
          <p class="eyebrow">
            <span class="status-dot" aria-hidden="true"></span>
            HELLO, WORLD · OPEN TO THE WEB
          </p>

          <h1 id="hero-title">
            <span class="hero-name">{profile.name}</span>
            <span class="hero-handle">/{profile.handle}</span>
          </h1>

          <p class="hero-role">{profile.role}</p>
          <p class="hero-intro">{profile.intro}</p>

          <div class="hero-actions">
            <a class="button button--primary" href="#projects">
              查看项目
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="m5 10h10M11 6l4 4-4 4" />
              </svg>
            </a>
            <a class="button button--secondary" href="#contact">联系我</a>
          </div>

          <div class="hero-console" aria-label="关注方向：视觉算法、系统性能与实用工具">
            <span aria-hidden="true">$</span>
            <code>focus --vision --systems --tooling</code>
            <span class="console-cursor" aria-hidden="true"></span>
          </div>
        </div>

        <figure class="portrait reveal reveal--two">
          <div class="portrait-offset" aria-hidden="true"></div>
          <div class="portrait-frame">
            <span class="frame-corner frame-corner--tl" aria-hidden="true"></span>
            <span class="frame-corner frame-corner--tr" aria-hidden="true"></span>
            <span class="frame-corner frame-corner--bl" aria-hidden="true"></span>
            <span class="frame-corner frame-corner--br" aria-hidden="true"></span>
            <Image
              class="portrait-image"
              src={avatarImage}
              alt="五水的插画头像：戴眼镜、穿橙色外套的人物"
              widths={[320, 480, 720]}
              sizes="(max-width: 700px) 78vw, (max-width: 1100px) 40vw, 440px"
              format="webp"
              quality={88}
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <svg class="portrait-reticle" viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="38" />
            <circle cx="60" cy="60" r="6" />
            <path d="M60 2v30M60 88v30M2 60h30M88 60h30" />
          </svg>

          <figcaption>
            <span>PROFILE_05</span>
            <span>USTC / CS</span>
          </figcaption>
        </figure>
      </div>

      <div class="hero-scroll" aria-hidden="true">
        <span>SCROLL TO EXPLORE</span>
        <i></i>
      </div>
    </section>

    <section class="section about" id="about" aria-labelledby="about-title">
      <div class="container">
        <header class="section-heading">
          <p class="section-kicker">01 / ABOUT</p>
          <h2 id="about-title">在算法、系统与应用之间。</h2>
          <p>WHO I AM</p>
        </header>

        <div class="about-grid">
          <article class="about-story panel">
            <p class="panel-label">BACKGROUND.md</p>
            <p class="about-lead">{profile.background}</p>

            <blockquote>
              <svg viewBox="0 0 28 28" aria-hidden="true">
                <path d="M6 6h7v7H9c0 4 2 6 4 7l-2 3c-4-2-6-6-6-11V6Zm12 0h7v7h-4c0 4 2 6 4 7l-2 3c-4-2-6-6-6-11V6Z" />
              </svg>
              <p>{profile.principle}</p>
            </blockquote>

            <div class="about-coordinates" aria-hidden="true">
              <span>SOURCE: USTC</span>
              <i></i>
              <span>DEV_MODE: ON</span>
            </div>
          </article>

          <div class="skills-panel panel">
            <div class="skills-header">
              <p class="panel-label">TOOLBOX.json</p>
              <span>{String(profile.skills.flatMap((group) => group.items).length).padStart(2, "0")} ITEMS</span>
            </div>

            <div class="skill-groups">
              {profile.skills.map((group) => {
                const skillId = `skill-${group.label
                  .toLowerCase()
                  .replace(/[^a-z0-9]+/g, "-")
                  .replace(/(^-|-$)/g, "")}`;

                return (
                  <section class="skill-group" aria-labelledby={skillId}>
                    <h3 id={skillId}>{group.label}</h3>
                    <ul>
                      {group.items.map((skill) => <li>{skill}</li>)}
                    </ul>
                  </section>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section projects" id="projects" aria-labelledby="projects-title">
      <div class="container">
        <header class="section-heading section-heading--projects">
          <p class="section-kicker">02 / PROJECTS</p>
          <h2 id="projects-title">把想法写成能用的东西。</h2>
          <p>SELECTED WORK</p>
        </header>

        <div class="project-grid">
          {projects.map((project, index) => (
            <article class:list={["project-card", { "project-card--featured": index === 0 }]}>
              <div class="project-topline">
                <span class="project-number">{project.number}</span>
                <span class="project-category">{project.category}</span>
              </div>

              <div class:list={["project-body", { "project-body--featured": index === 0 }]}>
                <div class="project-content">
                  <h3>{project.title}</h3>
                  <p>{project.description}</p>

                  {project.highlights && (
                    <ul class="project-highlights">
                      {project.highlights.map((highlight) => (
                        <li>
                          <span aria-hidden="true">+</span>
                          {highlight}
                        </li>
                      ))}
                    </ul>
                  )}
                </div>

                {index === 0 && (
                  <figure class="project-visual">
                    <div class="project-image-frame">
                      <Image
                        class="project-image"
                        src={robomasterHeroImage}
                        alt="昏暗走廊中亮起红色灯光的 RoboMaster 英雄机器人"
                        widths={[480, 720, 960, 1280]}
                        sizes="(max-width: 650px) calc(100vw - 80px), (max-width: 840px) calc(100vw - 100px), (max-width: 1180px) 38vw, 430px"
                        format="webp"
                        quality={86}
                        loading="lazy"
                      />
                      <span class="project-visual-reticle" aria-hidden="true"></span>
                    </div>
                    <figcaption>
                      <span>RoboMaster 英雄机器人</span>
                      <span>/ UNIT 1</span>
                    </figcaption>
                  </figure>
                )}
              </div>

              <footer class="project-footer">
                <ul class="tag-list" aria-label={`${project.title} 技术标签`}>
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>

                {project.links.length > 0 && (
                  <nav class="project-links" aria-label={`${project.title} 相关链接`}>
                    {project.links.map((link) => (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {link.label}
                        <svg viewBox="0 0 18 18" aria-hidden="true">
                          <path d="M5 13 13 5M7 5h6v6" />
                        </svg>
                      </a>
                    ))}
                  </nav>
                )}
              </footer>

              <span class="project-corner" aria-hidden="true"></span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section experience" id="experience" aria-labelledby="experience-title">
      <div class="container experience-layout">
        <header class="section-heading section-heading--stacked">
          <p class="section-kicker">03 / EXPERIENCE</p>
          <h2 id="experience-title">一路学习，也一路构建。</h2>
          <p class="section-summary">持续把赛场与课堂上的问题，变成可以验证、改进和复用的工程经验。</p>
        </header>

        <ol class="timeline">
          {experiences.map((item, index) => (
            <li>
              <div class="timeline-marker" aria-hidden="true">
                <span>{String(index + 1).padStart(2, "0")}</span>
              </div>
              <div class="timeline-content">
                <p class="timeline-period">{item.period}</p>
                <h3>{item.title}</h3>
                <p class="timeline-org">{item.organization}</p>
                <p class="timeline-description">{item.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section contact" id="contact" aria-labelledby="contact-title">
      <div class="container">
        <div class="contact-panel">
          <svg class="contact-reticle" viewBox="0 0 180 180" aria-hidden="true">
            <circle cx="90" cy="90" r="54" />
            <circle cx="90" cy="90" r="14" />
            <path d="M90 0v55M90 125v55M0 90h55M125 90h55" />
          </svg>

          <div class="contact-copy">
            <p class="section-kicker">04 / CONTACT</p>
            <h2 id="contact-title">有想法？来交换信号。</h2>
            <p>项目、技术或有趣的工具，都欢迎聊聊。</p>
          </div>

          <address class="contact-links">
            {profile.contacts.map((link) => (
              <a
                href={link.href}
                target={opensNewWindow(link.href) ? "_blank" : undefined}
                rel={opensNewWindow(link.href) ? "noopener noreferrer" : undefined}
              >
                <span class="contact-kind">
                  {link.kind === "email" ? "MAIL" : link.kind === "profile" ? "GIT" : "WWW"}
                </span>
                <span class="contact-detail">
                  <strong>{link.label}</strong>
                  <span>{link.display}</span>
                </span>
                <svg viewBox="0 0 22 22" aria-hidden="true">
                  <path d="M5 17 17 5M8 5h9v9" />
                </svg>
              </a>
            ))}
          </address>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p>© {currentYear} {profile.name} / {profile.handle}</p>
      <p>BUILT WITH ASTRO · NO TRACKERS</p>
      <a href="#top">
        回到顶部
        <span aria-hidden="true">↑</span>
      </a>
    </div>
  </footer>
</Layout>
